{
  "company_id": "A_L_Canada",
  "display_name": "A & L Canada Laboratories Inc.",

  "detection": {
    "match_strings": [
      "A & L Canada",
      "A&L Canada",
      "Jetstream Road",
      "A & L Canada Laboratories Inc.",
      "A & L Canada Laboratories"
    ],
    "priority": 10
  },

  "disable_universal_rules": true,

  "regex": [
    {
      "id": "REPORT_NO",
      "label": "Report Number",
      "pattern": "(?:REPORT\\s*NO\\.?[:\\s]*)?(C[0-9A-Z]{4,6}-[0-9A-Z]{4,6})",
      "action": "suggest"
    },
    {
      "id": "ACCOUNT_NUMBER",
      "label": "Account Number",
      "pattern": "ACCOUNT\\s*NUMBER[:\\s]*([0-9]{5})",
      "action": "ignore"
    },
    {
      "id": "TO_NAME",
      "label": "Client Name",
      "pattern": "TO:?\\s*([A-Z][A-Za-z\\s\\-']{2,80})",
      "action": "ignore"
    },
    {
      "id": "CLIENT_PHONE",
      "label": "Client Phone",
      "pattern": "Phone[:\\s]*([0-9\\-\\(\\)\\s]{8,20})",
      "action": "ignore"
    },
    {
      "id": "PO_NUMBER",
      "label": "PO Number",
      "pattern": "PO#[:\\s]*([A-Za-z0-9\\- ]{2,40})",
      "action": "ignore"
    },
    {
      "id": "LAB_NUMBER",
      "label": "Lab Number",
      "pattern": "(?:LAB\\s*NUMBER[:\\s]*|NUMBER[:\\s]*)([0-9]{4,10})",
      "action": "suggest"
    },
    {
      "id": "SAMPLE_ID",
      "label": "Sample ID",
      "pattern": "(?:SAMPLE\\s*ID|ID)[:\\s]*([A-Za-z0-9\\-]{3,40})",
      "action": "suggest"
    }
  ],

  "layout": [
    {
      "id": "ignore_company_block",
      "rect": { "x0": 0.00, "y0": 0.80, "x1": 0.60, "y1": 1.00 },
      "action": "ignore"
    }
  ],

  "barcode_qr": []
}
